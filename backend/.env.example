# База данных PostgreSQL (боевой вариант)
DATABASE_URL=postgresql+psycopg2://pas_user:pas_secret@localhost:5432/production_accounting
#
# Локально без настройки PostgreSQL (файл ./dev.db в каталоге backend):
# DATABASE_URL=sqlite+pysqlite:///./dev.db

# JWT
JWT_SECRET_KEY=замените_на_длинную_случайную_строку
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS (через запятую)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:8000

# Файлы
FILE_STORAGE_PATH=./storage/uploads
FILES_ENCRYPTION_KEY_BASE64=
# Сгенерировать: python -c "import os,base64; print(base64.b64encode(os.urandom(32)).decode())"

# Логи
LOG_PATH=./logs/app.log

# Redis (опционально, кэш аналитики)
REDIS_URL=
ANALYTICS_CACHE_TTL_SECONDS=300

# Email
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@example.com
SMTP_TLS=true

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Уведомления: роли через запятую (событие defect_created)
NOTIFY_ROLES_DEFECT_CREATED=admin,worker,constructor
NOTIFY_ROLES_SCHEME_UPDATED=admin,constructor

# Интеграция ERP / 1С
ERP_ADAPTER=mock
ERP_BASE_URL=http://localhost:9999/erp
ERP_API_TOKEN=
ERP_TIMEOUT_SECONDS=30

# Версия API и каталог обновлений клиентов (относительно cwd при запуске uvicorn из backend)
APP_VERSION=1.0.0
UPDATES_ROOT=../updates
UPDATES_MANIFEST_NAME=manifest.json
